# Environment Variables Template (copy to .env.local for local overrides)

# Vite loads mode-specific files committed in this repo:
#   npm run build:landing  ->  .env.landing  (mode: landing)
#   npm run build:app      ->  .env.app      (mode: app)
# Vite does NOT support --envFile; use --mode only.

# Backend API URL (production)
VITE_API_BASE_URL=https://api.randevum.tr

# App Base URL (dashboard - subdomain)
VITE_APP_BASE_URL=https://app.randevum.tr

# Landing / marketing site URL
VITE_LANDING_URL=https://randevum.tr

# Public booking base URL
VITE_PUBLIC_BOOKING_URL=https://randevum.tr/b

# Optional: Analytics/Monitoring IDs
# VITE_GA_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://...

# Optional: Feature Flags
# VITE_ENABLE_DARK_MODE=true
# VITE_ENABLE_PWA=true
